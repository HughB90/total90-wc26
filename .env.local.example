# --- Supabase (existing) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Opta / Stats Perform (Soccer Premium bundle) ---
# Source: ~/.openclaw/workspace/keys/opta-api.json
# - outletApiKey  → OPTA_OUTLET_KEY
# - secretKey1    → OPTA_SECRET_KEY
# In prod, set both in Vercel env. In local dev, you can omit and the client
# will fall back to reading keys/opta-api.json from the workspace.
OPTA_OUTLET_KEY=
OPTA_SECRET_KEY=

# --- Cron auth ---
# Random 32+ char string. Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`.
# Used by /api/cron/score-wc26-matches and /api/news/fetch.
CRON_SECRET=

# --- News pipeline (existing) ---
XAI_API_KEY=
